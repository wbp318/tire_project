# .gitattributes — force GitHub Linguist to detect & count ALL languages.
#
# By default Linguist hides "prose" (Markdown/Text), "data" (JSON/CSV/YAML),
# documentation, vendored and generated files from the repository language bar.
# Every rule below opts those file types back IN so the language breakdown
# reflects everything in the repo.
#
# Docs: https://github.com/github-linguist/linguist/blob/master/docs/overrides.md

# ---------------------------------------------------------------------------
# Markup / web
# ---------------------------------------------------------------------------
*.html      linguist-detectable
*.htm       linguist-detectable
*.xhtml     linguist-detectable
*.css       linguist-detectable
*.scss      linguist-detectable
*.sass      linguist-detectable
*.less      linguist-detectable
*.svg       linguist-detectable
*.xml       linguist-detectable
*.xsl       linguist-detectable
*.vue       linguist-detectable
*.svelte    linguist-detectable
*.astro     linguist-detectable

# ---------------------------------------------------------------------------
# Prose / documentation (normally excluded)
# ---------------------------------------------------------------------------
*.md        linguist-detectable
*.markdown  linguist-detectable
*.mdx       linguist-detectable
*.rst       linguist-detectable
*.txt       linguist-detectable
*.adoc      linguist-detectable
*.asciidoc  linguist-detectable
*.org       linguist-detectable
*.tex       linguist-detectable

# ---------------------------------------------------------------------------
# Data / config (normally excluded)
# ---------------------------------------------------------------------------
*.json      linguist-detectable
*.json5     linguist-detectable
*.jsonc     linguist-detectable
*.yaml      linguist-detectable
*.yml       linguist-detectable
*.toml      linguist-detectable
*.ini       linguist-detectable
*.csv       linguist-detectable
*.tsv       linguist-detectable
*.env       linguist-detectable

